# Copy this file to ~/automation/state/PROJECT.env and replace placeholders.
REPO_PATH="/home/codex-auto/repos/PROJECT"
GITHUB_OWNER="OWNER"
GITHUB_REPO="PROJECT"
BASE_BRANCH="main"
REMOTE_NAME="origin"
AUTOMATION_ROOT="/home/codex-auto/automation"
PROMPT_DIR="/home/codex-auto/automation/prompts"
PROFILES_PATH="/home/codex-auto/automation/codex-profiles.json"
GH_CONFIG_DIR="/home/codex-auto/automation/state/gh-config"
PROFILES=""
LOCAL_CHECK=""
STACK_CONTEXT=""
MAX_REPAIR_ATTEMPTS="3"
LOCAL_CHECK_TIMEOUT="45m"
CI_TIMEOUT="45m"
CODEX_TIMEOUT="2h"

# Optional KeePassXC token loading. Leave blank to use existing gh auth or GH_TOKEN.
KEEPASS_DB=""
KEEPASS_KEY_FILE=""
KEEPASS_ENTRY_PATH=""
KEEPASS_NO_PASSWORD="1"
